# --- GreenZone backend env vars ---

# Server port (Railway sets this automatically; for local dev keep 3000)
PORT=3000

# PostgreSQL connection string.
# - On Railway: this is auto-injected as DATABASE_URL when you add a Postgres plugin.
# - For local dev: paste a local Postgres URL, OR leave blank to use a local SQLite-ish
#   in-memory fallback (the server falls back to an in-memory store automatically if
#   DATABASE_URL is missing — fine for quick testing, NOT for production).
DATABASE_URL=

# Comma-separated list of allowed origins for CORS.
# In production set this to your Netlify URL (and any custom domain).
# Chrome extensions are allowed automatically (chrome-extension://...).
# Example: CORS_ORIGINS=https://greenzone.netlify.app,https://greenzone.com
CORS_ORIGINS=http://localhost:5173

# Secret token the extension must send in the X-Admin-Token header to POST/DELETE bets.
# Pick any long random string. Keep it secret.
ADMIN_TOKEN=change-me-to-a-long-random-string
